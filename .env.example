# MongoDB
MONGODB_URI=mongodb://localhost:27017/adweb

# JWT (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Razorpay — test mode until website approval (Standard Checkout)
RAZORPAY_ENV=test
NEXT_PUBLIC_RAZORPAY_ENV=test
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_TEST_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_TEST_KEY_SECRET=your_razorpay_test_secret
RAZORPAY_TEST_WEBHOOK_SECRET=your_razorpay_test_webhook_secret
RAZORPAY_LIVE_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_LIVE_KEY_SECRET=your_razorpay_live_secret
RAZORPAY_LIVE_WEBHOOK_SECRET=your_razorpay_live_webhook_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_test_webhook_secret

# Content pricing (in paise — 3900 = ₹39)
CONTENT_PRICE_PAISE=3900

# Bump when you change public/preview/cover.jpg (stops browser showing old image)
NEXT_PUBLIC_PREVIEW_VERSION=1

# Set to true to bypass Razorpay and test S3 photos without payment (local only)
NEXT_PUBLIC_DEV_SKIP_PAYMENT=false

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=your-private-bucket-name

# AWS CloudFront (optional — falls back to S3 presigned URLs)
AWS_CLOUDFRONT_DOMAIN=dxxxxxxxxxxxxx.cloudfront.net
AWS_CLOUDFRONT_KEY_PAIR_ID=APKAXXXXXXXXXXXXXXXX
AWS_CLOUDFRONT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
